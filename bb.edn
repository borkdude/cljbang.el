{:tasks
 {:requires ([babashka.fs :as fs])
  :init (def emacs (or (System/getenv "EMACS") "emacs"))

  test {:doc "Run the ERT suite"
        :task (shell emacs "--batch" "-L" "." "-L" "test"
                     "-l" "ert" "-l" "test/cljbang-test.el"
                     "-f" "ert-run-tests-batch-and-exit")}

  compile {:doc "Byte-compile, warnings are errors"
           :task (shell emacs "--batch" "-L" "."
                        "--eval" "(setq byte-compile-error-on-warn t)"
                        "-f" "batch-byte-compile"
                        "cljbang-core.el" "cljbang.el" "cljbang-mode.el")}

  bench {:doc "Compare the compile and run cost against plain elisp"
         :task (shell emacs "--batch" "-L" "." "-l" "bench-compile.el")}

  clean {:doc "Remove byte-compiled files"
         :task (doseq [f (fs/glob "." "**.elc")] (fs/delete f))}

  ci {:doc "What CI runs"
      :depends [compile test]}}}
